<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#f1e2f2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Раздел «Грамотность»"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#4d324c"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выберите упражнение для тренировки"
            android:textSize="16sp"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:id="@+id/layout_describe_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#ebd2eb">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎯 Описание предмета"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#7b3f8a"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Опишите случайный предмет за 3 минуты. Тренирует словарный запас и умение формулировать мысли."
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Нажмите, чтобы начать"
                    android:textSize="14sp"
                    android:textColor="#7b3f8a"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:id="@+id/layout_interview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#e4c5e4">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎤 Симулятор собеседования"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#9152a5"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="5 случайных вопросов из базы (всего 30). Тренирует навыки ответов на интервью."
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Нажмите, чтобы начать"
                    android:textSize="14sp"
                    android:textColor="#9152a5"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:id="@+id/layout_marathon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#dbb2db">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📝 Лексический марафон"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#a665bd"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Назовите как можно больше слов по заданному признаку за 1 минуту. 15 разных заданий."
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Нажмите, чтобы начать"
                    android:textSize="14sp"
                    android:textColor="#a665bd"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Рекомендуется выполнять упражнения ежедневно для расширения словарного запаса."
            android:textSize="12sp"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>