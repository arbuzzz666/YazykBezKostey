<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#f1e2f2">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Лексический марафон"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#4d324c"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Назовите как можно больше слов"
        android:textSize="14sp"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tv_marathon_task"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#e4c5e4"
        android:padding="20dp"
        android:gravity="center"
        android:text="Загрузка задания..."
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#bb6fbc"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_marathon_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="01:00"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#bb6fbc"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_word_counter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Названо слов: 0"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_start_marathon"
            android:layout_width="0dp"
            android:layout_height="79dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#bb6fbc"
            android:textColor="#FFFFFF"
            android:text="▶ Начать"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_word_said"
            android:layout_width="0dp"
            android:layout_height="79dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:alpha="0.5"
            android:backgroundTint="#c98cc9"
            android:enabled="false"
            android:text="След. слово"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_stop_marathon"
        android:layout_width="200dp"
        android:layout_height="69dp"
        android:layout_marginBottom="16dp"
        android:alpha="0.5"
        android:backgroundTint="#d6a9d7"
        android:textColor="#FFFFFF"
        android:enabled="false"
        android:text="Завершить"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tv_marathon_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нажмите «Начать» для старта"
        android:textSize="14sp"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_back_marathon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Назад к упражнениям"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#d6a9d7"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp"/>

</LinearLayout>